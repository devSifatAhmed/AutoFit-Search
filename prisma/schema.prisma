generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id            String    @id @default(uuid())
  shopifyGid    String    @unique
  domain        String?
  name          String?

  fields        Field[]
  rows          SearchRow[]
  suggestions   FilterSuggestion[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Field {
  id            String    @id @default(uuid())
  shopId        String
  shop          Shop      @relation(fields: [shopId], references:[shopifyGid], onDelete: Cascade)

  type          FieldType
  label         String
  placeholder   String?
  visibility    Visibility
  sortOrder     SortOrder

  rangeStart    Int?
  rangeEnd      Int?

  values        RowValue[]
  suggestions   FilterSuggestion[]

  position      Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([shopId, id])
  @@unique([shopId, position])
  @@index([shopId])
}

enum FieldType {
  SELECT
  RANGE
}

enum SortOrder {
  A_Z
  Z_A
  DB_ORDER
  POPULARITY
}

enum Visibility {
  VISIBLE
  HIDDEN
}

model SearchRow {
  id            String    @id @default(uuid())
  shopId        String
  shop          Shop      @relation(fields: [shopId], references:[shopifyGid], onDelete: Cascade)

  values        RowValue[]
  attachments   RowAttachment[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shopId])
}

model RowValue {
  id            String    @id @default(uuid())

  rowId         String
  row           SearchRow @relation(fields: [rowId], references: [id], onDelete: Cascade)

  fieldId       String
  field         Field     @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  value         String?
  minValue      Int?
  maxValue      Int?

  @@unique([rowId, fieldId])
  @@index([fieldId, value])
  @@index([fieldId, minValue, maxValue])
}

model RowAttachment {
  id            String    @id @default(uuid())

  rowId         String
  row           SearchRow @relation(fields: [rowId], references: [id], onDelete: Cascade)

  type          AttachmentType
  shopifyGid    String

  @@unique([rowId, shopifyGid])
  @@index([shopifyGid])
}

enum AttachmentType {
  PRODUCT
  COLLECTION
}

model FilterSuggestion {
  id            String    @id @default(uuid())
  
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [shopifyGid], onDelete: Cascade)

  fieldId       String
  field         Field     @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  value         String
  
  @@unique([shopId, fieldId, value])
  @@index([shopId, fieldId])
}