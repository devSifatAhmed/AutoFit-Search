
<script>
    document.addEventListener("DOMContentLoaded", ()=>{
        const windowData = window.autoFitConfig ? window.autoFitConfig : null;
        if(windowData !== null){
            console.log("AutoFit Search app embeded...");
            console.log("AutoFit Search config data: ", windowData);
        }else{
            console.log("AutoFit Search app not embeded yet...");
        }
    });
</script>

